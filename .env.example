# Bayse Markets credentials
BAYSE_API_KEY=your_bayse_api_key_here
BAYSE_BASE_URL=https://relay.bayse.markets

# Poke API (backend orchestration)
POKE_API_KEY=your_poke_api_key_here
POKE_WEBHOOK_URL=https://api.poke.com/webhooks/your_webhook_id

# Bot configuration
DRY_RUN=true
BANKROLL=100.0
MAX_POSITION_FRACTION=0.05
MIN_EDGE=0.03
POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
