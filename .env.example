# Bayse Markets credentials
# Get these from https://docs.bayse.markets/authentication after API waitlist approval
# Both keys are required: public key for identity, secret key for HMAC-SHA256 signing
BAYSE_PUBLIC_KEY=your_bayse_public_key_here
BAYSE_SECRET_KEY=your_bayse_secret_key_here
BAYSE_BASE_URL=https://relay.bayse.markets

# Poke API (backend orchestration)
POKE_API_KEY=your_poke_api_key_here
POKE_WEBHOOK_URL=https://api.poke.com/webhooks/your_webhook_id

# Telegram bot integration
# Create a bot via @BotFather on Telegram to obtain the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# The chat or group ID where signals and alerts will be sent
# Send a message to @userinfobot to find your chat ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Bot configuration
DRY_RUN=true
BANKROLL=100.0
MAX_POSITION_FRACTION=0.05
MIN_EDGE=0.03
POLL_INTERVAL_SECONDS=300
LOG_LEVEL=INFO

# Series slug to trade (e.g. crypto-btc-15min for BTC 15-min markets)
SERIES_SLUG=crypto-btc-15min
# Trading currency (NGN or USD)
CURRENCY=NGN
